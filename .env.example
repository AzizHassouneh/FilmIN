# FilmIN environment template. Copy to .env and fill in real values.
# Prisma does not auto-load .env; prisma.config.ts imports "dotenv/config".

# Postgres connection string (Neon recommended for prod).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# TMDB API key — free, legal catalog source. https://www.themoviedb.org/settings/api
TMDB_API_KEY=""

# Auth.js (NextAuth v5) secret. Generate with: npx auth secret
AUTH_SECRET=""

# Cloudinary — free image hosting for headshot uploads (prod only).
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Leave blank for local dev (files go to public/uploads instead).
CLOUDINARY_URL=""
